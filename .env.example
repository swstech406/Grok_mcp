# grok-mcp 运行配置示例。复制为 .env 并填入真实值：
#   cp .env.example .env   （Windows PowerShell：Copy-Item .env.example .env）
# 注意：.env 已在 .gitignore / .dockerignore 中排除，真实凭证不会进入版本库或镜像。

# ===== 上游 CPA 配置（CPA_API_KEY 必填）=====
# CPA 网关根地址（不含尾部 /）。
# 容器内访问「宿主机上」的 CPA：Windows/mac 用 host.docker.internal；Linux 需配合 extra_hosts（见 compose）。
CPA_BASE_URL=http://host.docker.internal:8317
# CPA 配置 api-keys 中的一个 key，grok-mcp 用它作为上游 Bearer。
CPA_API_KEY=replace-with-your-cpa-api-key

# ===== grok-mcp HTTP 服务 =====
# 传输模式（容器固定 http）。
GROK_TRANSPORT=http
# 监听地址。
GROK_HTTP_ADDR=:8080
# SQLite 文件路径（对应 compose 中挂载的 /app/data 卷）。
GROK_DB_PATH=/app/data/grok-mcp.db
# 默认限流：每分钟请求数，未单独设限的 Key 使用此值。
GROK_DEFAULT_RATE_LIMIT=60

# ===== 管理 API 鉴权（HTTP 模式必填）=====
# 保护 /admin/v1/* 的静态 Bearer。强烈建议用强随机串，例如：
#   openssl rand -hex 32
GROK_ADMIN_TOKEN=replace-with-a-strong-random-token

# ===== 可选 =====
# 默认上游模型。
GROK_MODEL=grok-4.3
# 上游 HTTP 超时（秒），搜索类请求较慢，保持较大值。
GROK_HTTP_TIMEOUT=120
# 设为 1/true/yes 输出调试日志到 stderr。
# GROK_MCP_DEBUG=1
