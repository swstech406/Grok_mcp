# grok-search-mcp Linux 本地运行配置示例。复制为 .env 并填入真实值：
#   cp .env.example .env
#   mkdir -p data
# 注意：.env 已在 .gitignore 中排除，真实凭证不会进入版本库。

# ===== 上游 CPA 配置（空数据库首次启动时 CPA_API_KEY 必填）=====
CPA_BASE_URL=http://127.0.0.1:8317
CPA_API_KEY=replace-with-real-cpa-api-key
# responses（默认）、chat_completions 或 anthropic_messages
GROK_UPSTREAM_PROTOCOL=responses

# ===== grok-search-mcp HTTP 服务 =====
GROK_HTTP_ADDR=:8080
GROK_DB_PATH=./data/grok-search-mcp.db

# ===== Usage 数据保留与维护 =====
# 原始明细保留 7 天，之后按小时聚合；小时聚合保留 90 天，之后按天聚合；
# 日聚合保留 730 天。维护任务会定期清理过期数据并 checkpoint 主库和 debug 库的 WAL。
GROK_USAGE_RAW_RETENTION_DAYS=7
GROK_USAGE_HOURLY_RETENTION_DAYS=90
GROK_USAGE_DAILY_RETENTION_DAYS=730
GROK_USAGE_MAINTENANCE_INTERVAL=1h

# ===== 面板 API（/panel/v1，必填）=====
# 空库启动时会自动创建 admin 用户；日志只输出下列 0600 JSON 凭据文件的路径。
GROK_JWT_SECRET=replace-with-a-strong-random-32-byte-jwt-secret
# 留空时默认派生为 <GROK_DB_PATH>.bootstrap-admin。
# GROK_BOOTSTRAP_CREDENTIALS_PATH=./data/grok-search-mcp.db.bootstrap-admin
# 仅在数据库还没有 server_settings 行时使用；之后始终以面板持久化设置为准。
# disabled（默认）、invite 或 free。
GROK_INITIAL_REGISTRATION_MODE=disabled
# 每位用户最多拥有的 MCP API Key 行数；禁用仍计数，删除释放容量，范围 1-1000。
GROK_MAX_API_KEYS_PER_USER=20
# 登录、注册和密码修改共享的 bcrypt 并发上限，范围 1-64。
GROK_AUTH_PASSWORD_MAX_CONCURRENT=4
# 不同无效 API Key 的并发数据库解析上限；相同 Key 的并发 miss 会合并，范围 1-1024。
GROK_AUTH_KEY_MISS_MAX_CONCURRENT=32

# 用户限额（RPM / success limit）以 tier 为唯一来源，在 Tier Management 页维护。
# direct（默认）始终使用 TCP 对端 RemoteAddr，并完全忽略转发 Header；没有无 Header 绕过。
GROK_CLIENT_IP_MODE=direct
# trusted_proxy 模式必填，逗号分隔可信“直接对端”代理的 IPv4/IPv6 CIDR。
# 只有直接对端命中此列表时才读取 X-Real-IP / X-Forwarded-For；可信代理仍必须清理并重建 Header。
# GROK_CLIENT_IP_MODE=trusted_proxy
# GROK_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128,172.18.0.0/16
# trusted_proxy 模式下，不可信直接对端返回 403；缺失、重复、冲突或格式错误的转发身份返回 400。
# 面板登录/注册与 /mcp API key 鉴权前限流共用同一个启动时信任边界。
GROK_SEARCH_MCP_IP_RPM=300
# 每个 64 分片最多保留的独立 IP 令牌桶数量；默认总上限为 64 * 2048，最大 65536/分片。
GROK_SEARCH_MCP_IP_MAX_ENTRIES_PER_SHARD=2048
# 分片已满且没有过期条目时，新 IP 按进程随机哈希共享固定降级桶，不再增加 map 条目；最大 1024/分片。
GROK_SEARCH_MCP_IP_FALLBACK_BUCKETS_PER_SHARD=16
# 流式搜索同时在途上限的环境默认值；用户上限必须小于或等于全局上限。
# 服务初始化后可在管理面板的「服务设置」中热更新，SQLite 持久化值优先于环境变量。
# 容量耗尽时立即返回 503 和 Retry-After，不在服务内排队占用 goroutine/socket。
GROK_SEARCH_MCP_GLOBAL_SEARCH_CONCURRENCY=16
GROK_SEARCH_MCP_USER_SEARCH_CONCURRENCY=4
# 已鉴权用户 RPM 状态表的容量上限与固定降级桶数量，范围分别为 1-65536 和 1-1024。
GROK_AUTH_USER_RPM_MAX_ENTRIES=16384
GROK_AUTH_USER_RPM_FALLBACK_BUCKETS=64

# ===== 可选 =====
GROK_MODEL=grok-4.3
GROK_HTTP_TIMEOUT=120
# GROK_SEARCH_MCP_DEBUG=1

# ===== 上游请求代理（可选）=====
# 项目显式代理必须同时设置 GROK_PROXY_URL 和 GROK_PROXY_ENABLED=true。
# 未启用项目显式代理时，程序会回退读取标准 HTTP 客户端代理环境变量：
# HTTP_PROXY、HTTPS_PROXY 和 NO_PROXY。
# GROK_PROXY_URL=http://127.0.0.1:7890
# GROK_PROXY_ENABLED=true
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=127.0.0.1,localhost
