# grok-mcp Linux 本地运行配置示例。复制为 .env 并填入真实值：
#   cp .env.example .env
#   mkdir -p data
# 注意：.env 已在 .gitignore 中排除，真实凭证不会进入版本库。

# ===== 上游 CPA 配置（空数据库首次启动时 CPA_API_KEY 必填）=====
CPA_BASE_URL=http://127.0.0.1:8317
CPA_API_KEY=replace-with-real-cpa-api-key
# responses（默认）、chat_completions 或 anthropic_messages
GROK_UPSTREAM_PROTOCOL=responses

# ===== grok-mcp HTTP 服务 =====
GROK_HTTP_ADDR=:8080
GROK_DB_PATH=./data/grok-mcp.db

# ===== Usage 数据保留与维护 =====
# 原始明细保留 7 天，之后按小时聚合；小时聚合保留 90 天，之后按天聚合；
# 日聚合保留 730 天。维护任务会定期清理过期数据并 checkpoint 主库和 debug 库的 WAL。
GROK_USAGE_RAW_RETENTION_DAYS=7
GROK_USAGE_HOURLY_RETENTION_DAYS=90
GROK_USAGE_DAILY_RETENTION_DAYS=730
GROK_USAGE_MAINTENANCE_INTERVAL=1h

# ===== 面板 API（/panel/v1，必填）=====
# 空库启动时会自动创建 admin 用户，并在控制台 / Docker 日志中输出一次性随机密码。
GROK_JWT_SECRET=replace-with-a-strong-random-32-byte-jwt-secret

# 用户限额（RPM / success limit）以 tier 为唯一来源，在 Tier Management 页维护。
# 仅当 X-Real-IP 或 X-Forwarded-For 能解析出有效 IP 时，才在 API key 鉴权前限制 /mcp；
# Header 缺失、为空或无有效 IP 时直接跳过。面板登录/注册的 IP 保护遵循同一规则。
GROK_MCP_IP_RPM=300
# 流式搜索同时在途上限的环境默认值；用户上限必须小于或等于全局上限。
# 服务初始化后可在管理面板的「服务设置」中热更新，SQLite 持久化值优先于环境变量。
# 容量耗尽时立即返回 503 和 Retry-After，不在服务内排队占用 goroutine/socket。
GROK_MCP_GLOBAL_SEARCH_CONCURRENCY=16
GROK_MCP_USER_SEARCH_CONCURRENCY=4
# 应用会直接信任上述 Header：X-Real-IP 优先，否则取 X-Forwarded-For 中第一个有效 IP。
# 必须禁止客户端直连应用，并由反向代理覆盖 X-Real-IP、清理后重建 X-Forwarded-For。

# ===== 可选 =====
GROK_MODEL=grok-4.3
GROK_HTTP_TIMEOUT=120
# GROK_MCP_DEBUG=1

# ===== 上游请求代理（可选）=====
# 设置 GROK_PROXY_URL 后会作为显式代理使用；未设置显式代理时，程序会回退读取
# 标准 HTTP 客户端代理环境变量：HTTP_PROXY、HTTPS_PROXY 和 NO_PROXY。
# GROK_PROXY_URL=http://127.0.0.1:7890
# GROK_PROXY_ENABLED=true
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=127.0.0.1,localhost
