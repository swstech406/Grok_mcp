# grok-mcp Linux 本地运行配置示例。复制为 .env 并填入真实值：
#   cp .env.example .env
#   mkdir -p data
# 注意：.env 已在 .gitignore 中排除，真实凭证不会进入版本库。

# ===== 上游 CPA 配置（CPA_API_KEY 必填）=====
CPA_BASE_URL=http://127.0.0.1:8317
CPA_API_KEY=replace-with-real-cpa-api-key

# ===== grok-mcp HTTP 服务 =====
GROK_HTTP_ADDR=127.0.0.1:8080
GROK_DB_PATH=./data/grok-mcp.db

# ===== 面板 API（/panel/v1，必填）=====
# 默认仅允许空库 bootstrap 首个管理员；后续用户由管理员在面板中管理。
GROK_PANEL_REGISTRATION=bootstrap-only
# 可选：设置后，bootstrap 注册请求必须携带 JSON 字段 setup_token。
# GROK_SETUP_TOKEN=replace-with-one-time-bootstrap-token
GROK_JWT_SECRET=replace-with-a-strong-random-32-byte-jwt-secret

# 用户限额（RPM / success limit）以 tier 为唯一来源，在 Tier Management 页维护；
# GROK_DEFAULT_USER_RPM 仅作为内存限流器的兜底 RPM。
GROK_DEFAULT_USER_RPM=60
# API key 鉴权前按 TCP 来源 IP 限制 /mcp 请求，降低无效 key 探测与认证存储 DoS 风险。
GROK_MCP_IP_RPM=300

# ===== 可选 =====
GROK_MODEL=grok-4.3
GROK_HTTP_TIMEOUT=120
# GROK_MCP_DEBUG=1
