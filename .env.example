# grok-mcp Linux 本地运行配置示例。复制为 .env 并填入真实值：
#   cp .env.example .env
#   mkdir -p data
# 注意：.env 已在 .gitignore 中排除，真实凭证不会进入版本库。

# ===== 上游 CPA 配置（CPA_API_KEY 必填）=====
CPA_BASE_URL=http://127.0.0.1:8317
CPA_API_KEY=test

# ===== grok-mcp HTTP 服务 =====
GROK_HTTP_ADDR=:8080
GROK_DB_PATH=./data/grok-mcp.db

# ===== 面板 API（/panel/v1，必填）=====
# 注册/登录无需鉴权；其他面板接口需 Authorization: Bearer <JWT>。
GROK_JWT_SECRET=replace-with-a-strong-random-jwt-secret

# 用户限额（RPM / success limit）以 tier 为唯一来源，在 Tier Management 页维护；
# GROK_DEFAULT_USER_RPM 仅作为内存限流器的兜底 RPM。
GROK_DEFAULT_USER_RPM=60

# ===== 可选 =====
GROK_MODEL=grok-4.3
GROK_HTTP_TIMEOUT=120
# GROK_MCP_DEBUG=1
